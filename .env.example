# ====================================
# KRYZEN VIP BOT - Environment Config
# ====================================

# Bot
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=KRYZENBot
ADMIN_IDS=123456789,987654321

# Database
DATABASE_URL=sqlite+aiosqlite:///data/kryzen.db

# Redis (optional)
REDIS_URL=

# AI APIs
OPENAI_API_KEY=sk-your-openai-key
DEEPAI_API_KEY=your-deepai-key

# App
DEBUG=False
LOG_LEVEL=INFO
TIMEZONE=Asia/Tashkent

# Premium prices (Telegram Stars)
PREMIUM_PRICE_1MONTH=499
PREMIUM_PRICE_3MONTHS=1299
PREMIUM_PRICE_LIFETIME=4999

# Referral rewards
REFERRAL_BONUS=100
REFERRAL_PREMIUM_BONUS=500

# Rate limits
RATE_LIMIT_PER_MINUTE=20
FLOOD_PROTECTION_SECONDS=2

# Encryption
SECRET_KEY=change-me-to-random-hex-32-chars